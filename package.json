    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.1",
    "three": "^0.170.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@theatre/core": "^0.7.2",
