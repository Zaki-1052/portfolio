    "husky": "^9.1.7",
    "leva": "^0.9.36",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.1",
    "r3f-perf": "^7.2.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.4.3",
