{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/portfolio/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lora|Fira Code|Inter))/i]",
        "message": "Font not provided by the design system. Available: Lora, Fira Code, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|iconLeft|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, iconLeft, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|ghost|text)$/]",
        "message": "<Button> variant must be one of 'solid' | 'ghost' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DepthScale'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|magnification|key|ref|className|style|children)$/]",
        "message": "<DepthScale> doesn't accept that prop. Declared props: id, name, magnification."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|href|description|tags|meta|glass|style|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: title, href, description, tags, meta, glass, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScaleLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:scale|magnification|dot|style|key|ref|className|style|children)$/]",
        "message": "<ScaleLabel> doesn't accept that prop. Declared props: scale, magnification, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScaleSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:scale|magnification|title|kicker|children|full|align|style|key|ref|className|style|children)$/]",
        "message": "<ScaleSection> doesn't accept that prop. Declared props: scale, magnification, title, kicker, children, full, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScaleSection'] > JSXAttribute[name.name='scale'] > Literal[value!=/^(?:tissue|cellular|chromatin|protein|code|expression)$/]",
        "message": "<ScaleSection> scale must be one of 'tissue' | 'cellular' | 'chromatin' | 'protein' | 'code' | 'expression'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScaleSection'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<ScaleSection> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:muted|accent)$/]",
        "message": "<Tag> tone must be one of 'muted' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|stars|href|perms|key|ref|className|style|children)$/]",
        "message": "<TerminalItem> doesn't accept that prop. Declared props: name, description, stars, href, perms."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
